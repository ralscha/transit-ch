{
  "name": "transit-ch",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "postbuild": "bread-compressor -a gzip,brotli,zstd dist/transit-ch/browser",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write .",
    "lint": "ng lint",
    "check": "npm run lint && npm run build"
  },
  "private": true,
  "packageManager": "npm@11.17.0",
  "dependencies": {
    "@angular/common": "22.0.4",
    "@angular/compiler": "22.0.4",
    "@angular/core": "22.0.4",
    "@angular/forms": "22.0.4",
    "@angular/platform-browser": "22.0.4",
    "@angular/router": "22.0.4",
    "@angular/service-worker": "22.0.4",
    "@jsverse/transloco": "8.4.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "22.0.4",
    "@angular/cli": "22.0.4",
    "@angular/compiler-cli": "22.0.4",
    "@eslint/js": "10.0.1",
    "angular-eslint": "22.0.0",
    "bread-compressor-cli": "4.1.0",
    "eslint": "10.6.0",
    "prettier": "3.8.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "piscina": "5.2.0"
  }
}
