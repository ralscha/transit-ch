{
  "name": "transit-ch",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "postbuild": "bread-compressor -a gzip,brotli,zstd dist/transit-ch/browser",
    "watch": "ng build --watch --configuration development",
    "format": "npx prettier --write .",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@angular/common": "21.2.7",
    "@angular/compiler": "21.2.7",
    "@angular/core": "21.2.7",
    "@angular/forms": "21.2.7",
    "@angular/platform-browser": "21.2.7",
    "@angular/router": "21.2.7",
    "@angular/service-worker": "21.2.7",
    "@jsverse/transloco": "8.3.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "21.2.6",
    "@angular/cli": "21.2.6",
    "@angular/compiler-cli": "21.2.7",
    "@eslint/js": "10.0.1",
    "angular-eslint": "21.3.1",
    "bread-compressor-cli": "4.0.0",
    "eslint": "10.2.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  }
}
